---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "../../../../lib/createSlug"
import BlogFilter from "../../../../components/ui/BlogFilter.astro";

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection("blog", ({ id }) => !id.startsWith("zh/"));
  allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const tags = [...new Set(allPosts.flatMap(post => post.data.tags || []))].sort();
  const allYears = [...new Set(allPosts.map(post => post.data.pubDate.getFullYear().toString()))].sort((a, b) => b - a);

  return allYears.flatMap((year) => {
    const filteredPosts = allPosts.filter((post) => {
      return post.data.pubDate.getFullYear().toString() === year;
    });
    return paginate(filteredPosts, {
      params: { year },
      pageSize: 10,
      props: { tags, years: allYears },
    });
  });
}

const { page, tags, years } = Astro.props;
const { year } = Astro.params;
---

<BaseLayout title={"Archive - " + year} sideBarActiveItemID="blog" noindex={true}>
  <div class="mb-5">
    <div class="text-3xl w-full font-black uppercase tracking-tighter mb-8 italic">Archive: {year}</div>
  </div>

  <BlogFilter tags={tags} years={years} activeYear={year} lang="en" />

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-2 border-base-content w-full p-4 min-w-full">
        <p class="font-bold uppercase italic text-xl tracking-widest text-center py-20 opacity-30">Nothing here!</p>
      </div>
    ) : (
      <div class="relative border-l-4 border-base-content ml-4 md:ml-8 mt-10">
        {page.data.map((post) => (
          <div class="mb-10 ml-8 group">
            <div class="absolute w-4 h-4 bg-base-content rounded-none -left-[10px] mt-1.5 transition-transform group-hover:scale-125" />
            <div class="flex flex-col">
              <a 
                href={"/blog/" + createSlug(post.data.title, post.slug)}
                class="inline-block w-fit"
              >
                <h3 class="text-2xl md:text-3xl font-black uppercase relative pb-1 overflow-hidden">
                  {post.data.title}
                  <span class="absolute bottom-0 left-0 w-full h-1 bg-base-content transform -translate-x-[101%] transition-transform duration-300 group-hover:translate-x-0" />
                </h3>
              </a>
              <p class="text-lg text-base-content/70 mt-2 line-clamp-2 font-medium">{post.data.description}</p>
              <div class="flex gap-2 mt-2">
                {post.data.badge && <span class="px-2 py-0.5 border-2 border-base-content text-[10px] font-black uppercase">{post.data.badge}</span>}
                <time class="text-xs font-black uppercase opacity-50 flex items-center">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }

  <div class="flex justify-between mt-10">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="px-6 py-3 border-4 border-base-content font-black uppercase tracking-widest hover:bg-base-content hover:text-base-100 transition-colors">
          Previous
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="px-6 py-3 border-4 border-base-content font-black uppercase tracking-widest hover:bg-base-content hover:text-base-100 transition-colors">
          Next
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>
