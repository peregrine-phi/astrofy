---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug"

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog", ({ id }) => !id.startsWith("zh/"));
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout title="Blog" sideBarActiveItemID="blog" noindex={!!page.url.prev}>
  <h1 class="sr-only">Blog</h1>

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">Sorry!</p>
        <p>There are no blog posts to show at the moment. Check back later!</p>
      </div>
    ) : (
      <div class="relative border-l-2 border-base-content/20 ml-4 md:ml-8 mt-10">
        {page.data.map((post) => (
          <div class="mb-10 ml-8 group" data-block-region={post.data.block_region}>
            <div class="absolute w-3 h-3 bg-base-content rounded-none -left-[7px] mt-1.5 transition-transform group-hover:scale-125" />
            <div class="flex flex-col">
              <a 
                href={"/blog/" + createSlug(post.data.title, post.slug)}
                class="inline-block w-fit"
              >
                <h3 class="text-2xl md:text-3xl font-black uppercase relative pb-1 overflow-hidden">
                  {post.data.title}
                  <span class="absolute bottom-0 left-0 w-full h-1 bg-base-content transform -translate-x-[101%] transition-transform duration-300 group-hover:translate-x-0" />
                </h3>
              </a>
              <p class="text-lg text-base-content/70 mt-2 line-clamp-2">{post.data.description}</p>
              <div class="flex gap-2 mt-2">
                {post.data.badge && <span class="badge badge-outline rounded-none text-xs">{post.data.badge}</span>}
                <time class="text-xs opacity-50 flex items-center">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          {" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>{" "}
          Recent posts
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          Older Posts{" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            {" "}
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>
