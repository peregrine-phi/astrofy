---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/ui/HorizontalCard.astro";
---

<BaseLayout title="Gallery" sideBarActiveItemID="gallery">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Gallery</div>
  </div>

  <p class="mb-10 text-justify">
    Welcome to my gallery. Here I share visual moments and inspirations.
  </p>

  <ul>
    <li>
      <HorizontalCard
        title="Moment 1"
        img="/post_img.webp"
        desc="A brief description of this visual moment."
        url="/gallery"
      />
      <div class="divider my-0" />
    </li>
    <li>
      <HorizontalCard
        title="Moment 2"
        img="/post_img.webp"
        desc="Another moment captured in time."
        url="/gallery"
      />
      <div class="divider my-0" />
    </li>
  </ul>
</BaseLayout>
