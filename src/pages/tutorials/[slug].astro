---
import { CollectionEntry, getCollection } from "astro:content";
import { TutorialSchema } from "../../content/config";
import TutorialLayout from "../../layouts/TutorialLayout.astro";

export async function getStaticPaths() {
  const itemEntries = await getCollection("tutorials", ({ id }) => !id.startsWith("zh/"));
  return itemEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"tutorials">;
}

const { entry } = Astro.props;
const item: TutorialSchema = entry.data;
const { Content } = await entry.render();
---

<TutorialLayout
  title={item.title}
  description={item.description}
  heroImage={item.heroImage}
  updatedDate={item.updatedDate}
  pricing={item.pricing}
  oldPricing={item.oldPricing}
  checkoutUrl={item.checkoutUrl}
  badge={item.badge}
  custom_link={item.custom_link}
  custom_link_label={item.custom_link_label}
>
  <Content />
</TutorialLayout>
