---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AIPlayground from "../../../components/AIPlayground";
---

<BaseLayout title="AI 实验场 | Astrofy" sideBarActiveItemID="ai-playground">
  <div className="pb-12 mt-5">
    <div className="text-center mb-10">
      <div className="inline-block border-4 border-black bg-primary text-primary-content p-4 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] -rotate-1">
        <h1 className="text-4xl font-black uppercase tracking-tighter">AI 实验场</h1>
      </div>
    </div>
    
    <AIPlayground client:load lang="zh" />
  </div>
</BaseLayout>
