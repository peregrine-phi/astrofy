---
const { title, desc, img, colorClass = "bg-primary", url } = Astro.props;
---

<div class="mobile-gallery-item border-4 border-black bg-black shadow-[4px_4px_0_#000] overflow-hidden flex flex-col">
  <!-- Header/Color Area -->
  <div class={`${colorClass} p-4 border-b-4 border-black pixel-pattern flex items-center justify-between`}>
    <span class="bg-black text-white px-3 py-1 text-sm font-black uppercase tracking-tighter border-2 border-white/20">
      {title}
    </span>
    {url && (
      <a href={url} target="_blank" rel="noopener noreferrer" class="bg-black text-white p-1 border-2 border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter">
          <path d="M7 17l10-10M7 7h10v10"/>
        </svg>
      </a>
    )}
  </div>
  
  <!-- Image Area -->
  <div class="bg-white p-2">
    {img ? (
      <img src={img} alt={title} class="w-full h-48 object-cover border-2 border-black rendering-pixelated" />
    ) : (
      <div class="w-full h-48 bg-gray-100 border-2 border-black flex items-center justify-center opacity-20">
        <span class="font-black">PIXEL</span>
      </div>
    )}
  </div>

  <!-- Content Area -->
  <div class="bg-white p-4 border-t-4 border-black">
    <p class="text-xs font-bold leading-relaxed">{desc}</p>
  </div>
</div>

<style>
  .pixel-pattern {
    background-image: radial-gradient(rgba(0,0,0,0.1) 1px, transparent 1px);
    background-size: 4px 4px;
  }
  
  .rendering-pixelated {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
</style>
