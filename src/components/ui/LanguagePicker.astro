---
import { languages } from "../../i18n/ui";

const currentLang = Astro.currentLocale || "en";
const { pathname } = Astro.url;

// A simple utility to get the URL for a different language
function getLanguageUrl(targetLang: string) {
  if (targetLang === "en") {
    return pathname.replace(/^\/zh/, "") || "/";
  } else {
    return pathname.startsWith("/zh") ? pathname : `/zh${pathname}`;
  }
}
---

<div class="flex gap-2">
  {
    Object.entries(languages).map(([lang, label]) => (
      <a
        href={getLanguageUrl(lang)}
        class={`btn btn-sm px-3 ${currentLang === lang ? "btn-primary" : "btn-ghost"}`}
      >
        {label}
      </a>
    ))
  }
</div>
