---
const isZh = Astro.currentLocale === "zh";
---

<!-- Search Trigger Button (Sidebar) -->
<div class="px-4 mb-5">
  <button
    id="search-trigger"
    class="flex items-center gap-3 px-4 py-2.5 w-full bg-base-content/5 hover:bg-base-content/10 border border-base-content/5 rounded-2xl transition-all group"
    aria-label="Search"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 group-hover:opacity-70 group-hover:scale-110 transition-all">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <span class="text-sm font-medium opacity-40 group-hover:opacity-60 transition-opacity">
      {isZh ? "搜索博文..." : "Search posts..."}
    </span>
    <div class="grow"></div>
    <kbd class="kbd kbd-sm opacity-20 group-hover:opacity-40 transition-opacity">/</kbd>
  </button>
</div>
