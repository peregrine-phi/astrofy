---
// AndroidSystem.astro
const apps = [
  { name: "StyleKit", icon: "sparkles", color: "bg-purple-500", url: "https://www.stylekit.top/" },
  { name: "Astro", icon: "rocket", color: "bg-orange-500", url: "https://astro.build" },
  { name: "Tailwind", icon: "wind", color: "bg-sky-500", url: "https://tailwindcss.com" },
  { name: "DaisyUI", icon: "face-smile", color: "bg-indigo-600", url: "https://daisyui.com" },
];
---

<div class="fixed inset-0 z-[200] bg-[#1a1a1a] font-sans overflow-hidden select-none text-white">
  <!-- Wallpaper -->
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-900 via-purple-900 to-pink-900 opacity-60"></div>
  <div class="absolute inset-0 backdrop-blur-3xl"></div>

  <!-- Status Bar -->
  <div class="absolute top-0 left-0 right-0 h-7 flex justify-between items-center px-4 text-[12px] font-medium z-10">
    <div id="android-time">12:00</div>
    <div class="flex items-center gap-1.5 opacity-90">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21c-4.418 0-8-3.582-8-8s3.582-8 8-8 8 3.582 8 8-3.582 8-8 8zm0-2c3.314 0 6-2.686 6-6s-2.686-6-6-6-6 2.686-6 6 2.686 6 6 6z"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2.05v2.02c3.39.49 6 3.39 6 6.93 0 3.9-3.1 7-7 7s-7-3.1-7-7c0-3.54 2.61-6.44 6-6.93V2.05C5.94 2.56 2 7.32 2 13c0 5.52 4.48 10 10 10s10-4.48 10-10c0-5.68-3.94-10.44-10-10.95z"/></svg>
      <div class="w-6 h-3 border border-white/40 rounded-[2px] relative flex items-center px-[1px]">
        <div class="bg-white h-full w-[80%] rounded-[1px]"></div>
        <div class="absolute -right-[3px] w-[2px] h-[4px] bg-white/40 rounded-r-sm"></div>
      </div>
    </div>
  </div>

  <!-- App Grid -->
  <div class="absolute inset-0 top-12 bottom-24 p-6 grid grid-cols-4 grid-rows-6 gap-4 content-start">
    {apps.map(app => (
      <a href={app.url} target="_blank" class="flex flex-col items-center gap-2 group active:scale-95 transition-transform">
        <div class={`${app.color} w-14 h-14 rounded-2xl shadow-lg flex items-center justify-center text-white`}>
            {app.icon === 'sparkles' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>}
            {app.icon === 'rocket' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11l-3 3z"/><path d="M9 12H4s.5-1 1-4c1.5 0 3 .5 3 .5L9 12z"/><path d="M15 11l3 3s.5 1.5 1.5 3c-3 1.5-4.5 1-4.5 1l-3-3s0-1.5 1-4.5c1.5 0 2 .5 2 .5z"/></svg>}
            {app.icon === 'wind' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5z"/><circle cx="12" cy="12" r="3"/></svg>}
            {app.icon === 'face-smile' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>}
        </div>
        <span class="text-[11px] font-medium text-white shadow-sm">{app.name}</span>
      </a>
    ))}

    <!-- Custom Frontend Dev App -->
    <div id="android-frontend-launcher" class="flex flex-col items-center gap-2 active:scale-95 transition-transform cursor-pointer">
      <div class="bg-white w-14 h-14 rounded-full shadow-lg flex items-center justify-center text-blue-600 border-4 border-blue-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
      </div>
      <span class="text-[11px] font-medium text-white text-center leading-tight">Frontend<br/>Resources</span>
    </div>
  </div>

  <!-- Dock -->
  <div class="absolute bottom-10 left-4 right-4 h-20 bg-white/10 backdrop-blur-md rounded-[32px] flex items-center justify-around px-4 border border-white/10">
    <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </div>
    <div class="w-12 h-12 bg-blue-400 rounded-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center overflow-hidden">
        <div class="w-full h-full bg-gradient-to-br from-blue-500 via-red-500 to-yellow-400 flex items-center justify-center">
            <div class="w-6 h-6 bg-white rounded-full"></div>
        </div>
    </div>
    <div class="w-12 h-12 bg-red-500 rounded-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
  </div>

  <!-- Navigation Bar -->
  <div class="absolute bottom-0 left-0 right-0 h-10 flex justify-around items-center px-12 z-10">
    <div class="w-4 h-4 border-2 border-white/60 rotate-45 border-t-0 border-r-0"></div>
    <div class="w-4 h-4 border-2 border-white/60 rounded-full"></div>
    <div class="w-3.5 h-3.5 border-2 border-white/60 rounded-sm"></div>
  </div>

  <!-- Bottom Sheet (App Content) -->
  <div id="android-sheet" class="fixed inset-x-0 bottom-0 top-20 bg-[#f8f9fa] rounded-t-[32px] transform translate-y-full transition-transform duration-300 ease-out z-[300] text-black">
    <div class="h-1.5 w-12 bg-gray-300 rounded-full mx-auto mt-3 mb-6"></div>
    <div class="px-6">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold">Frontend Resources</h2>
            <button id="android-close" class="p-2 hover:bg-gray-200 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="space-y-4">
            {apps.map(app => (
                <a href={app.url} target="_blank" class="flex items-center gap-4 p-4 bg-white rounded-2xl border border-gray-100 shadow-sm active:bg-gray-50 transition-colors">
                    <div class={`${app.color} w-12 h-12 rounded-xl flex items-center justify-center text-white`}>
                        {app.icon === 'sparkles' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>}
                        {app.icon === 'rocket' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11l-3 3z"/><path d="M9 12H4s.5-1 1-4c1.5 0 3 .5 3 .5L9 12z"/><path d="M15 11l3 3s.5 1.5 1.5 3c-3 1.5-4.5 1-4.5 1l-3-3s0-1.5 1-4.5c1.5 0 2 .5 2 .5z"/></svg>}
                        {app.icon === 'wind' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5z"/><circle cx="12" cy="12" r="3"/></svg>}
                        {app.icon === 'face-smile' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>}
                    </div>
                    <div>
                        <div class="font-bold">{app.name}</div>
                        <div class="text-xs text-gray-500">Resource Link</div>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-gray-400"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </a>
            ))}
        </div>
    </div>
  </div>

  <a href="/neighbors" class="absolute top-8 right-4 text-white/40 hover:text-white text-[10px] underline z-10">Close System</a>
</div>

<script is:inline>
  (function() {
    const timeDisplay = document.getElementById('android-time');
    const launcher = document.getElementById('android-frontend-launcher');
    const sheet = document.getElementById('android-sheet');
    const closeBtn = document.getElementById('android-close');

    function updateTime() {
      const now = new Date();
      timeDisplay.innerText = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
    }
    setInterval(updateTime, 1000);
    updateTime();

    launcher.addEventListener('click', () => {
      sheet.classList.remove('translate-y-full');
    });

    closeBtn.addEventListener('click', () => {
      sheet.classList.add('translate-y-full');
    });

    // Close on outside click (simple version)
    document.addEventListener('click', (e) => {
      if (e.target.closest('#android-frontend-launcher')) return;
      if (!e.target.closest('#android-sheet') && !sheet.classList.contains('translate-y-full')) {
        sheet.classList.add('translate-y-full');
      }
    });
  })();
</script>
