---
const { block_region } = Astro.props;
const locale = Astro.currentLocale || "en";
const isZh = locale === "zh";

const today = new Date();
const month = today.getMonth() + 1;
const day = today.getDate();
---

<div class="history-ticker" id="history-ticker" data-month={month} data-day={day} data-block-region={block_region} style="display: flex;">
  <div class="history-ticker__meta">
    <div class="history-ticker__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
    </div>
    <div class="history-ticker__label" id="history-ticker-label">
      {isZh ? "历史上的今天" : "On This Day"}
    </div>
    <div class="history-ticker__year-wrapper">
        <span class="history-ticker__year-display" id="history-year-display">----</span>
    </div>
  </div>
  
  <div class="history-ticker__divider"></div>
  
  <div class="history-ticker__content" id="history-content">
    <div class="history-ticker__track" id="history-track">
      <div class="history-ticker__item history-ticker__item--loading">
        <span class="history-ticker__loading-dot"></span>
        <span class="history-ticker__loading-dot"></span>
        <span class="history-ticker__loading-dot"></span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  function initHistoryTicker() {
    const ticker = document.getElementById('history-ticker');
    const track = document.getElementById('history-track');
    const content = document.getElementById('history-content');
    const yearDisplay = document.getElementById('history-year-display');
    const label = document.getElementById('history-ticker-label');
    if (!ticker || !track || !content || !yearDisplay) return;

    const lang = document.documentElement.lang || 'en';
    const isZh = lang.startsWith('zh');
    const month = ticker.dataset.month;
    const day = ticker.dataset.day;

    if (window._historyTickerInterval) {
      clearInterval(window._historyTickerInterval);
      window._historyTickerInterval = null;
    }
    track.style.transform = 'translateY(0)';
    track.innerHTML = `
      <div class="history-ticker__item history-ticker__item--loading">
        <span class="history-ticker__loading-dot"></span>
        <span class="history-ticker__loading-dot"></span>
        <span class="history-ticker__loading-dot"></span>
      </div>`;
    content.style.height = 'auto';
    yearDisplay.textContent = '----';
    label.textContent = isZh ? "历史上的今天" : "On This Day";

    const requestId = Date.now();
    window._historyLastRequestId = requestId;

    const url = isZh 
      ? 'https://v2.xxapi.cn/api/history'
      : `https://byabbe.se/on-this-day/${month}/${day}/events.json`;

    fetch(url)
      .then(res => res.json())
      .then(json => {
        if (window._historyLastRequestId !== requestId) return;

        let events = [];
        if (isZh) {
          if (json.code === 200 && json.data) events = json.data;
        } else {
          if (json.events) events = json.events.map(e => ({ year: e.year, text: e.description }));
        }

        if (!events.length) throw new Error('Empty data');

        if (isZh) {
          events = events.map(e => {
            const m = e.match(/^(\d+)年.*?日\s+(.*)$/);
            return m ? { year: m[1], text: m[2] } : { year: '', text: e };
          });
        }

        events.sort(() => Math.random() - 0.5);
        track.innerHTML = events.map(e => `
          <div class="history-ticker__item" data-year="${e.year}">
            <div class="history-ticker__text">${e.text}</div>
          </div>
        `).join('');

        const items = track.querySelectorAll('.history-ticker__item');
        
        function updateYear(year) {
            yearDisplay.style.opacity = '0';
            setTimeout(() => {
                yearDisplay.textContent = year || '----';
                yearDisplay.style.opacity = '1';
            }, 300);
        }

        requestAnimationFrame(() => {
          if (!items[0]) return;
          content.style.height = items[0].offsetHeight + 'px';
          updateYear(items[0].dataset.year);

          let idx = 0;
          window._historyTickerInterval = setInterval(() => {
            const currentItems = track.querySelectorAll('.history-ticker__item');
            if (!currentItems.length) return;
            
            idx = (idx + 1) % currentItems.length;
            const target = currentItems[idx];
            track.style.transform = `translateY(-${target.offsetTop}px)`;
            content.style.height = target.offsetHeight + 'px';
            updateYear(target.dataset.year);
          }, 5000);
        });
      })
      .catch(err => {
        if (window._historyLastRequestId !== requestId) return;
        console.error('History ticker error:', err);
        track.innerHTML = `<div class="history-ticker__item"><div class="history-ticker__text" style="opacity:0.5;font-style:italic">${isZh ? '暂时无法加载' : 'Unable to load'}</div></div>`;
      });
  }

  initHistoryTicker();
  document.addEventListener('astro:after-swap', initHistoryTicker);
</script>

<style>
  .history-ticker {
    @apply flex items-center gap-6 px-7 py-5 mb-10 rounded-2xl border border-base-300 bg-base-200/30 backdrop-blur-xl transition-all duration-300;
  }

  .history-ticker:hover {
    @apply border-primary/20 shadow-lg shadow-primary/5;
  }

  .history-ticker__meta {
    @apply flex flex-col gap-2 shrink-0 min-w-[6.5rem];
  }

  .history-ticker__icon {
    @apply flex items-center text-primary opacity-80 ml-0.5;
  }

  .history-ticker__label {
    @apply text-[0.65rem] font-extrabold uppercase tracking-widest text-base-content/40 leading-none;
  }

  .history-ticker__year-wrapper {
    @apply h-[1.8rem] flex items-center;
  }

  .history-ticker__year-display {
    @apply text-[0.9rem] font-extrabold font-mono text-primary bg-primary/10 px-2.5 py-1 rounded-md transition-opacity duration-300 border border-primary/10;
  }

  .history-ticker__divider {
    @apply w-px h-16 shrink-0;
    background: linear-gradient(to bottom, transparent, var(--fallback-bc, oklch(var(--bc) / 0.08)), transparent);
  }

  .history-ticker__content {
    @apply flex-1 overflow-hidden relative transition-[height] duration-500 ease-in-out;
  }

  .history-ticker__track {
    @apply w-full transition-transform duration-700 ease-in-out;
    will-change: transform;
  }

  .history-ticker__item {
    @apply min-h-[5rem] flex items-center py-2 box-border;
  }

  .history-ticker__item--loading {
    @apply h-20 justify-start;
  }

  .history-ticker__loading-dot {
    @apply w-1 h-1 rounded-full bg-primary/50 mx-0.5;
    animation: ticker-dot 1.4s infinite;
  }
  .history-ticker__loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .history-ticker__loading-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes ticker-dot {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1.2); }
  }

  .history-ticker__text {
    @apply text-base text-base-content/80 leading-relaxed font-medium w-full break-words;
  }
</style>
