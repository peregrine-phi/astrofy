---
/**
 * ThemeSelector.astro - Compact Icon Version
 */
const themes = [
  { name: "lofi", label: "Lofi" },
  { name: "nord", label: "Nord" },
  { name: "dracula", label: "Dracula" },
  { name: "cupcake", label: "Cupcake" },
  { name: "emerald", label: "Emerald" },
  { name: "retro", label: "Retro" },
  { name: "winter", label: "Winter" },
];
---

<div class="dropdown dropdown-top dropdown-end">
  <div tabindex="0" role="button" class="btn btn-sm btn-ghost px-2" title="Change Theme">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.92 0 1.76-.74 1.76-1.67 0-.44-.18-.84-.46-1.13a1.59 1.59 0 0 1 0-2.25c.3-.3.7-.45 1.13-.45H17c3.87 0 7-3.13 7-7 0-4.42-5.37-8-12-8Z"/></svg>
  </div>
  <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-2xl bg-base-200/90 backdrop-blur-md rounded-xl w-44 mb-2 border border-base-content/10">
    {themes.map((theme) => (
      <li>
        <button class="theme-select-btn text-xs py-2" data-theme-set={theme.name}>
          {theme.label}
          <div class="flex gap-1 ml-auto">
            <div class="w-2 h-4 rounded-full bg-primary" data-theme={theme.name}></div>
            <div class="w-2 h-4 rounded-full bg-secondary" data-theme={theme.name}></div>
          </div>
        </button>
      </li>
    ))}
  </ul>
</div>

<script is:inline>
  function applyTheme() {
    const savedTheme = localStorage.getItem('theme') || 'lofi';
    document.documentElement.setAttribute('data-theme', savedTheme);
  }

  function initThemeSelector() {
    const themeButtons = document.querySelectorAll('.theme-select-btn');
    
    themeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = btn.getAttribute('data-theme-set');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);
        }
      });
    });
  }

  applyTheme();
  initThemeSelector();

  document.addEventListener('astro:after-swap', () => {
    applyTheme();
    initThemeSelector();
  });
</script>
