---
// src/components/ui/HotNews.astro
const { sourceId = 507, title = "今日要闻", initialCount = 6 } = Astro.props;
const proxyUrl = import.meta.env.PUBLIC_HOT_API_PROXY || 'https://api.allhot.top/api/open/v1';
---

<div class="hot-news-section mb-16" data-source-id={sourceId} data-initial-count={initialCount} data-proxy-url={proxyUrl}>
  <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
    <div class="flex items-center gap-4">
      <h2 class="text-4xl font-black tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-base-content to-base-content/60">
        {title}
      </h2>
      <span class="news-count-badge opacity-0 transition-opacity duration-500 badge badge-ghost font-mono text-xs">0 items</span>
    </div>
    <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.2em] text-base-content/40" id="news-status-wrapper">
      <span class="loading loading-double-ring loading-xs" id="news-loading"></span>
      <span id="news-update-time">初始化中...</span>
    </div>
  </div>
  
  <div id="news-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    <!-- 骨架屏占位 -->
    {[...Array(initialCount)].map(() => (
      <div class="skeleton-card h-28 rounded-2xl bg-base-200/50 animate-pulse"></div>
    ))}
  </div>

  <div class="flex justify-center mt-12 opacity-0 transition-all duration-700" id="load-more-wrapper">
    <button class="btn btn-outline btn-wide rounded-full border-base-content/10 hover:border-primary hover:bg-primary/5 hover:text-primary transition-all duration-300 group" id="load-more-btn">
      <span>查看更多热点</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </button>
  </div>

  <template id="news-item-template">
    <a href="#" target="_blank" class="news-card group relative flex flex-col justify-between p-6 rounded-2xl bg-base-100 border border-base-content/5 hover:border-primary/20 hover:shadow-2xl hover:shadow-primary/5 transition-all duration-500 ease-out overflow-hidden">
      <!-- 悬浮时的背景光晕 -->
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
      
      <div class="relative z-10 flex flex-col gap-3">
        <div class="flex items-center justify-between">
           <span class="news-rank font-mono text-xs font-black px-2 py-0.5 rounded bg-base-200 group-hover:bg-primary group-hover:text-primary-content transition-colors"></span>
           <div class="category-tag text-[9px] font-black uppercase tracking-tighter text-base-content/30 group-hover:text-primary/50">PEOPLE'S DAILY</div>
        </div>
        <h3 class="font-bold text-lg leading-snug group-hover:text-primary transition-colors line-clamp-2"></h3>
      </div>

      <div class="relative z-10 mt-4 flex items-center justify-end">
        <div class="w-8 h-px bg-base-content/5 group-hover:w-full group-hover:bg-primary/20 transition-all duration-500"></div>
        <div class="pl-2 opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </div>
      </div>
    </a>
  </template>
</div>

<script is:inline>
  function initHotNews() {
    const container = document.querySelector('.hot-news-section');
    if (!container) return;

    const sourceId = container.dataset.sourceId;
    const initialCount = parseInt(container.dataset.initialCount);
    const proxyUrl = container.dataset.proxyUrl;
    
    const list = container.querySelector('#news-list');
    const loading = container.querySelector('#news-loading');
    const updateTime = container.querySelector('#news-update-time');
    const loadMoreWrapper = container.querySelector('#load-more-wrapper');
    const loadMoreBtn = container.querySelector('#load-more-btn');
    const countBadge = container.querySelector('.news-count-badge');
    const template = container.querySelector('#news-item-template');

    let allNews = [];
    let visibleCount = initialCount;

    function renderNews(isInitial = false) {
      if (isInitial) list.innerHTML = '';
      
      const nextBatch = allNews.slice(list.children.length, visibleCount);
      
      nextBatch.forEach((item, index) => {
        const clone = template.content.cloneNode(true);
        const card = clone.querySelector('.news-card');
        const link = clone.querySelector('a');
        const titleEl = clone.querySelector('h3');
        const rankEl = clone.querySelector('.news-rank');

        link.href = item.jump_url;
        titleEl.textContent = item.title;
        rankEl.textContent = (list.children.length + 1).toString().padStart(2, '0');
        
        // 添加入场动画类
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        
        list.appendChild(clone);
        
        // 触发重绘并开启动画
        requestAnimationFrame(() => {
          const addedCard = list.lastElementChild;
          setTimeout(() => {
            addedCard.style.opacity = '1';
            addedCard.style.transform = 'translateY(0)';
          }, index * 50); // 错开入场时间
        });
      });

      // 隐藏或显示加载更多按钮
      if (visibleCount >= allNews.length) {
        loadMoreWrapper.classList.add('hidden');
      } else {
        loadMoreWrapper.classList.remove('opacity-0');
      }
    }

    const cleanProxyUrl = proxyUrl.replace(/\/+$/, '');
    const apiUrl = `${cleanProxyUrl}/sources/data?id=${sourceId}`;

    fetch(apiUrl)
    .then(res => {
      const cacheTime = res.headers.get('X-Cache-Time');
      const storageKey = `hotnews_time_${sourceId}`;
      let finalTime = cacheTime;

      if (cacheTime) {
        localStorage.setItem(storageKey, cacheTime);
      } else {
        finalTime = localStorage.getItem(storageKey);
      }

      const date = finalTime ? new Date(finalTime) : new Date();
      if (!finalTime) localStorage.setItem(storageKey, date.toISOString());

      const hours = date.getHours().toString().padStart(2, '0');
      const minutes = date.getMinutes().toString().padStart(2, '0');
      updateTime.textContent = `${finalTime ? '同步于' : '实时'} ${hours}:${minutes}`;
      
      return res.json();
    })
    .then(json => {
      if (json.code === 200 && json.data.list) {
        allNews = json.data.list;
        loading.classList.add('hidden');
        countBadge.textContent = `${allNews.length} 条热点`;
        countBadge.classList.remove('opacity-0');
        
        renderNews(true);
      }
    })
    .catch(err => {
      console.error('Failed to fetch news:', err);
      updateTime.textContent = '加载失败';
    });

    loadMoreBtn?.addEventListener('click', () => {
      visibleCount += 12; // 每次加载 12 条
      renderNews();
    });
  }

  initHotNews();
  document.addEventListener('astro:after-swap', initHotNews);
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .news-card {
    will-change: transform, opacity;
  }
  .skeleton-card {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(var(--bc), 0.05),
      transparent
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
</style>
