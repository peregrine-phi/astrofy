---
// src/components/ui/HotNews.astro
const { sourceId = 507, title = "今日要闻", count = 6 } = Astro.props;
const proxyUrl = import.meta.env.PUBLIC_HOT_API_PROXY || 'https://api.allhot.top/api/open/v1';
---

<div class="hot-news-section mb-10" data-source-id={sourceId} data-count={count} data-proxy-url={proxyUrl}>
  <div class="flex items-center justify-between mb-5">
    <h2 class="text-3xl font-bold flex items-center gap-3">
      {title}
      <span class="loading loading-ring loading-md opacity-50" id="news-loading"></span>
    </h2>
    <div class="text-sm opacity-50 font-mono" id="news-update-time"></div>
  </div>
  
  <div id="news-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- 新闻条目将由脚本动态注入 -->
  </div>

  <template id="news-item-template">
    <a href="#" target="_blank" class="group flex gap-4 p-4 rounded-xl bg-base-200/50 hover:bg-base-200 transition-all duration-300 border border-transparent hover:border-primary/20">
      <div class="news-image hidden sm:block shrink-0">
        <img src="" alt="" class="w-24 h-16 object-cover rounded-lg bg-base-300" />
      </div>
      <div class="flex flex-col justify-center gap-1 overflow-hidden">
        <h3 class="font-bold text-sm leading-tight group-hover:text-primary transition-colors line-clamp-2"></h3>
        <div class="flex items-center gap-2 text-[10px] opacity-40 uppercase tracking-widest font-bold">
          <span class="news-index"></span>
          <span class="news-category">PEOPLE'S DAILY</span>
        </div>
      </div>
    </a>
  </template>
</div>

<script is:inline>
  function initHotNews() {
    const containers = document.querySelectorAll('.hot-news-section');
    containers.forEach(container => {
      const sourceId = container.dataset.sourceId;
      const count = parseInt(container.dataset.count);
      const proxyUrl = container.dataset.proxyUrl;
      const list = container.querySelector('#news-list');
      const loading = container.querySelector('#news-loading');
      const updateTime = container.querySelector('#news-update-time');
      const template = container.querySelector('#news-item-template');

      if (!list || !template) return;

      // 移除可能存在的尾部斜杠，防止拼出 //sources/data 的情况
      const cleanProxyUrl = proxyUrl.replace(/\/+$/, '');
      const apiUrl = `${cleanProxyUrl}/sources/data?id=${sourceId}`;
      const apiKey = window.ALLHOT_API_KEY || ''; 

      const fetchOptions = {
        headers: {}
      };

      // 只有在没有使用代理（直连原站）时才尝试手动添加 Key
      if (proxyUrl.includes('api.allhot.top') && apiKey) {
        fetchOptions.headers['X-API-Key'] = apiKey;
      }

      let cacheTime = null;

      fetch(apiUrl, fetchOptions)
      .then(res => {
        // 尝试从 Header 获取 Worker 记录的真实缓存时间
        cacheTime = res.headers.get('X-Cache-Time');
        return res.json();
      })
      .then(json => {
        if (json.code === 200 && json.data.list) {
          if (loading) loading.classList.add('hidden');
          const data = json.data.list.slice(0, count);
          
          list.innerHTML = '';
          data.forEach((item, index) => {
            const clone = template.content.cloneNode(true);
            const link = clone.querySelector('a');
            const titleEl = clone.querySelector('h3');
            const imgEl = clone.querySelector('img');
            const indexEl = clone.querySelector('.news-index');

            link.href = item.jump_url;
            titleEl.textContent = item.title;
            indexEl.textContent = `#${index + 1}`;
            
            if (item.image_url) {
              imgEl.src = item.image_url;
            } else {
              const imgContainer = clone.querySelector('.news-image');
              if (imgContainer) imgContainer.remove();
            }

            list.appendChild(clone);
          });

          if (updateTime) {
            const date = cacheTime ? new Date(cacheTime) : new Date();
            const hours = date.getHours().toString().padStart(2, '0');
            const minutes = date.getMinutes().toString().padStart(2, '0');
            updateTime.textContent = `${cacheTime ? '数据生成于' : '实时更新'} ${hours}:${minutes}`;
          }
        }
      })
      .catch(err => {
        console.error('Failed to fetch news:', err);
        if (loading) loading.textContent = '加载失败';
      });
    });
  }

  initHotNews();
  document.addEventListener('astro:after-swap', initHotNews);
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
