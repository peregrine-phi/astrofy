---
/**
 * Comments.astro - Universal Theme Compatible Version
 * 评论组件 - 彻底修复深色模式下的“白块”问题，并保留极简下划线样式
 */

const { title } = Astro.props;
const lang = Astro.currentLocale === "zh" ? "zh-CN" : "en";

const ARTALK_SERVER = "https://comment.peregrinewang.me";
const ARTALK_SITE = "Peregrine";
---

<div class="divider my-16 opacity-20"></div>

<div class="comments-section max-w-full">
  <div class="flex items-center gap-2 mb-10 px-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <h2 class="text-lg font-bold tracking-tight opacity-70 uppercase">{lang === 'zh-CN' ? '交流与反馈' : 'Comments'}</h2>
  </div>

  <div class="comments-wrapper relative min-h-[250px]">
    <div id="ArtalkSkeleton" class="absolute inset-0 flex flex-col gap-6 w-full transition-opacity duration-700 z-10">
      <div class="skeleton h-32 w-full opacity-10 rounded-2xl"></div>
      <div class="skeleton h-20 w-full opacity-5 rounded-2xl"></div>
    </div>
    <div id="ArtalkComments" class="opacity-0 transition-all duration-1000 relative z-20"></div>
    
    <!-- Maintenance Message -->
    <div id="ArtalkMaintenance" class="hidden absolute inset-0 flex items-center justify-center text-center p-6 bg-base-content/[0.02] rounded-3xl border border-dashed border-base-content/20 animate-in fade-in duration-700">
      <div class="flex flex-col items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-30"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <p class="text-sm opacity-60 leading-relaxed">
          {lang === 'zh-CN' ? '评论功能正在维护中，请联系' : 'Comments are under maintenance, please contact'}<br/>
          <a href="mailto:contact_me@peregrinewang.me" class="link link-primary no-underline font-medium">contact_me@peregrinewang.me</a>
        </p>
      </div>
    </div>
  </div>
</div>

<link href={`${ARTALK_SERVER}/dist/Artalk.css`} rel="stylesheet" />
<script src={`${ARTALK_SERVER}/dist/Artalk.js`} is:inline></script>

<script is:inline define:vars={{ ARTALK_SERVER, ARTALK_SITE, lang, title }}>
  function initArtalk() {
    const el = document.getElementById("ArtalkComments");
    const skeleton = document.getElementById("ArtalkSkeleton");
    const maintenance = document.getElementById("ArtalkMaintenance");
    
    if (!el || el.classList.contains('artalk-initialized')) return;

    let hasLoaded = false;
    
    // 设置 10 秒超时
    const timeoutTimer = setTimeout(() => {
      if (!hasLoaded) {
        console.warn("Artalk load timeout - switching to maintenance mode");
        if (skeleton) {
          skeleton.classList.add("opacity-0");
          setTimeout(() => skeleton.style.display = 'none', 700);
        }
        if (maintenance) {
          maintenance.classList.remove("hidden");
        }
      }
    }, 10000);

    const artalk = Artalk.init({
      el: "#ArtalkComments",
      pageKey: window.location.pathname,
      pageTitle: title,
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      darkMode: document.documentElement.getAttribute('data-theme') === 'black' || 
                document.documentElement.getAttribute('data-theme') === 'dracula',
      locale: lang,
      pv: true,
    });

    artalk.on('list-loaded', () => {
      hasLoaded = true;
      clearTimeout(timeoutTimer);
      
      const comments = document.getElementById("ArtalkComments");
      if (skeleton) {
        skeleton.classList.add("opacity-0");
        setTimeout(() => skeleton.style.display = 'none', 700); 
      }
      if (comments) {
        comments.classList.remove("opacity-0");
        comments.classList.add("artalk-initialized");
      }
      if (maintenance) {
        maintenance.style.display = 'none';
      }
    });

    // Sync theme changes with Artalk
    const syncTheme = () => {
      const theme = document.documentElement.getAttribute('data-theme');
      const isDark = theme === 'black' || theme === 'dracula';
      artalk.setDarkMode(isDark);
    };
    
    window.addEventListener('theme-changed', syncTheme);
    document.addEventListener('astro:after-swap', syncTheme);
  }
  document.addEventListener("astro:page-load", initArtalk);
</script>

<style is:global>
  /* 全局变量覆盖 - 确保 Artalk 核心颜色变量跟随 DaisyUI */
  :root {
    --at-color-main: var(--fallback-p, oklch(var(--p))) !important;
    --at-color-bg: transparent !important;
    --at-color-border: var(--fallback-bc, oklch(var(--bc) / 0.1)) !important;
    --at-color-font: var(--fallback-bc, oklch(var(--bc))) !important;
    --at-color-deep: var(--fallback-b2, oklch(var(--b2))) !important;
    --at-color-sub: var(--fallback-bc, oklch(var(--bc) / 0.5)) !important;
  }

  /* 彻底修复各种主题下的“白块”或背景不匹配问题 */
  #ArtalkComments, 
  .atk-main-editor, 
  .atk-textarea, 
  .atk-editor-container,
  .atk-header input,
  .atk-editor-wrap,
  .atk-list-header,
  .atk-list-footer,
  .atk-grp,
  .atk-plug-panel-wrap,
  .atk-editor-plug-box {
    background-color: transparent !important;
    color: var(--fallback-bc, oklch(var(--bc))) !important;
  }

  /* 强制编辑器容器透明且符合整体审美 */
  .atk-main-editor {
    @apply border border-base-content/10 bg-base-content/[0.02] rounded-3xl p-4 transition-all duration-500 focus-within:bg-base-content/[0.05] focus-within:border-primary/30 !important;
    box-shadow: none !important;
  }

  /* 修正编辑器上方的 Header */
  .atk-header {
    @apply flex flex-wrap gap-2 mb-4 bg-transparent !important;
  }

  .atk-header input {
    @apply border-b border-base-content/10 transition-all focus:border-primary px-2 py-2 text-sm bg-transparent !important;
    border-top: none !important;
    border-left: none !important;
    border-right: none !important;
    border-radius: 0 !important;
  }

  /* 解决 Textarea 默认背景和占位符 */
  .atk-textarea {
    @apply py-4 min-h-[120px] bg-transparent !important;
  }
  
  .atk-textarea::placeholder {
    @apply opacity-30 !important;
  }

  /* 发送按钮 */
  .atk-send-btn {
    @apply btn btn-primary btn-md rounded-2xl px-10 border-none transition-all shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 !important;
  }

  /* 评论卡片样式 - 确保在深色主题下背景透明或微调 */
  .atk-comment-wrap {
    @apply border-none bg-base-content/[0.02] mb-4 p-6 rounded-3xl transition-colors hover:bg-base-content/[0.04] !important;
  }

  .atk-avatar img {
    @apply rounded-2xl shadow-sm !important;
  }

  /* 修正下拉列表和弹出层背景 - 使用模糊效果防止完全透明导致的重叠干扰 */
  .atk-layer-wrap {
    @apply rounded-2xl shadow-2xl border border-base-content/10 backdrop-blur-2xl bg-base-200/95 !important;
    color: var(--fallback-bc, oklch(var(--bc))) !important;
  }

  /* 修正列表中的预览项背景 */
  .atk-list-footer, .atk-error-wrap {
    background: transparent !important;
  }

  /* 修正所有残留链接色 */
  .atk-content a, .atk-nick, .atk-item.active, .atk-layer-wrap a, .atk-comment-count {
    color: var(--fallback-p, oklch(var(--p))) !important;
  }

  /* 修正底部版权信息 */
  .atk-footer, .atk-power {
    @apply opacity-20 text-[10px] grayscale transition-all hover:opacity-100 hover:grayscale-0 !important;
  }
</style>
