---
/**
 * Comments.astro - Premium Refined Version
 * 评论组件 - 深度适配 DaisyUI 主题系统
 */

const { title } = Astro.props;
const lang = Astro.currentLocale === "zh" ? "zh-CN" : "en";

const ARTALK_SERVER = "https://comment.peregrinewang.me";
const ARTALK_SITE = "Peregrine";
---

<div class="divider my-16 opacity-30"></div>

<div class="comments-section max-w-full">
  <div class="flex items-center gap-2 mb-8 px-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <h2 class="text-xl font-bold opacity-80">{lang === 'zh-CN' ? '交流与反馈' : 'Comments'}</h2>
  </div>

  <div class="comments-container relative min-h-[250px]">
    <!-- 骨架屏 Loading 状态 -->
    <div id="ArtalkSkeleton" class="absolute inset-0 p-8 flex flex-col gap-6 w-full transition-opacity duration-700 z-10">
      <div class="skeleton h-32 w-full opacity-20 rounded-2xl"></div>
      <div class="flex gap-4 items-center">
        <div class="skeleton w-12 h-12 rounded-full shrink-0 opacity-20"></div>
        <div class="flex flex-col gap-2 w-full">
          <div class="skeleton h-4 w-32 opacity-20"></div>
          <div class="skeleton h-4 w-full opacity-20"></div>
        </div>
      </div>
    </div>

    <!-- 评论区容器 -->
    <div id="ArtalkComments" class="opacity-0 transition-all duration-700 translate-y-4 relative z-20"></div>
  </div>
</div>

<link href={`${ARTALK_SERVER}/dist/Artalk.css`} rel="stylesheet" />
<script src={`${ARTALK_SERVER}/dist/Artalk.js`} is:inline></script>

<script is:inline define:vars={{ ARTALK_SERVER, ARTALK_SITE, lang, title }}>
  function initArtalk() {
    const el = document.getElementById("ArtalkComments");
    if (!el || el.classList.contains('artalk-initialized')) return;

    const artalk = Artalk.init({
      el: "#ArtalkComments",
      pageKey: window.location.pathname,
      pageTitle: title,
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      darkMode: "auto",
      locale: lang,
      pv: true,
    });

    artalk.on('list-loaded', () => {
      const skeleton = document.getElementById("ArtalkSkeleton");
      const comments = document.getElementById("ArtalkComments");
      
      if (skeleton) {
        skeleton.classList.add("opacity-0");
        setTimeout(() => skeleton.style.display = 'none', 700); 
      }
      if (comments) {
        comments.classList.remove("opacity-0");
        comments.classList.remove("translate-y-4");
        comments.classList.add("artalk-initialized");
      }
    });
  }

  // 支持 View Transitions
  document.addEventListener("astro:page-load", initArtalk);
</script>

<style is:global>
  /* 动态色彩变量 - 完美适配 DaisyUI 主题 */
  :root {
    --at-color-main: oklch(var(--p)) !important; /* 跟随主题主色 */
    --at-color-bg: transparent !important;
    --at-color-border: oklch(var(--bc) / 0.1) !important;
    --at-color-font: oklch(var(--bc)) !important;
    --at-color-deep: oklch(var(--b2)) !important;
    --at-color-sub: oklch(var(--bc) / 0.6) !important;
  }

  .comments-container {
    @apply p-1 md:p-6 rounded-[2.5rem] border border-base-content/5 bg-base-100/30 backdrop-blur-2xl transition-all duration-500 hover:border-base-content/10;
  }

  #ArtalkComments {
    --at-font-family: inherit !important;
  }

  /* 深度精致化 UI */
  .atk-main-editor {
    @apply border-none bg-base-content/5 rounded-3xl p-3 transition-all duration-300 focus-within:bg-base-content/[0.08] focus-within:shadow-inner !important;
  }

  .atk-header input {
    @apply bg-transparent border-b border-base-content/10 focus:border-primary transition-colors py-2 !important;
  }

  .atk-send-btn {
    @apply btn btn-primary btn-sm rounded-2xl px-8 border-none shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-all !important;
  }

  /* 评论卡片样式 */
  .atk-comment-wrap {
    @apply border-b border-base-content/5 py-8 last:border-none transition-colors hover:bg-base-content/[0.02] rounded-2xl px-4 !important;
  }

  .atk-avatar img {
    @apply rounded-2xl shadow-md !important;
  }

  .atk-nick {
    @apply font-bold text-base-content transition-colors hover:text-primary !important;
  }

  .atk-content {
    @apply text-[0.95rem] leading-relaxed opacity-90 !important;
  }

  /* 修正暗色模式下的视觉表现 */
  [data-theme="dark"] .atk-main-editor {
    @apply bg-white/5 focus-within:bg-white/10 !important;
  }
</style>
