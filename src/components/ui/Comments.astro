---
/**
 * Comments.astro
 * 评论组件 - 基于 Artalk
 *
 * 颜色抽象化说明：
 * 本组件使用的颜色变量已提取至底部的 <style> 块中。
 * 未来如需全局统一调整颜色，可将这些变量迁移至 src/styles/variables.css 或通过 Tailwind 配置管理。
 */

const { title } = Astro.props;
const lang = Astro.currentLocale === "zh" ? "zh-CN" : "en";

// 这里的 server 地址建议后续通过环境变量或 config.ts 统一管理
const ARTALK_SERVER = "https://comment.peregrinewang.me"; // 请替换为你的实际后端地址
const ARTALK_SITE = "Peregrine";
---

<div class="divider my-10"></div>

<div class="comments-container relative min-h-[200px]">
  <!-- 骨架屏 Loading 状态 -->
  <div id="ArtalkSkeleton" class="absolute inset-0 p-6 flex flex-col gap-4 w-full transition-opacity duration-500 z-10">
    <div class="skeleton h-24 w-full opacity-50"></div>
    <div class="skeleton h-4 w-28 opacity-50 mt-2"></div>
    <div class="skeleton h-4 w-full opacity-50"></div>
    <div class="skeleton h-4 w-3/4 opacity-50"></div>
  </div>

  <!-- 评论区容器，初始透明，加载完成后淡入 -->
  <div id="ArtalkComments" class="opacity-0 transition-opacity duration-500 relative z-20"></div>
</div>

<!-- Artalk Assets -->
<link href={`${ARTALK_SERVER}/dist/Artalk.css`} rel="stylesheet" />
<script src={`${ARTALK_SERVER}/dist/Artalk.js`} is:inline></script>

<script is:inline define:vars={{ ARTALK_SERVER, ARTALK_SITE, lang, title }}>
  document.addEventListener("astro:page-load", () => {
    const el = document.getElementById("ArtalkComments");
    if (!el) return;

    const artalk = Artalk.init({
      el: "#ArtalkComments",
      pageKey: window.location.pathname,
      pageTitle: title,
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      darkMode: "auto",
      locale: lang,
      pv: true, // 统计阅读量
    });

    // 监听加载完成事件，隐藏骨架屏，显示评论区
    artalk.on('list-loaded', () => {
      const skeleton = document.getElementById("ArtalkSkeleton");
      const comments = document.getElementById("ArtalkComments");
      
      if (skeleton) {
        skeleton.classList.add("opacity-0");
        // 等待淡出动画结束后彻底隐藏，防止遮挡点击
        setTimeout(() => skeleton.style.display = 'none', 500); 
      }
      if (comments) {
        comments.classList.remove("opacity-0");
      }
    });
  });
</script>

<style is:global>
  /* 颜色抽象化 Token (Color Abstraction Tokens) */
  :root {
    /* 适配 lofi 主题：将蓝色主色调改为黑色/深灰色 */
    --at-color-main: theme("colors.base-content") !important; 
    --at-color-bg: transparent !important;
    --at-color-border: theme("colors.base-300") !important;
    --at-color-font: theme("colors.base-content") !important;
  }

  .comments-container {
    @apply mt-16 p-8 rounded-3xl border border-base-200 bg-base-100/40 backdrop-blur-md shadow-xl shadow-base-content/5 transition-all duration-300;
  }

  /* 深度美化 Artalk 内部元素 */
  #ArtalkComments {
    --at-color-deep: theme("colors.base-200") !important;
    --at-color-sub: theme("colors.base-content / 0.6") !important;
    --at-font-family: theme("fontFamily.sans") !important;
  }

  /* 输入框美化：去除生硬边框，增加悬浮感 */
  .atk-main-editor {
    @apply border-none bg-base-200/50 rounded-2xl p-2 transition-all duration-300 focus-within:bg-base-200 !important;
  }

  .atk-header input {
    @apply bg-transparent border-b border-base-300 focus:border-base-content transition-colors !important;
  }

  /* 按钮美化：适配 lofi 的黑白简约风 */
  .atk-send-btn {
    @apply btn btn-sm rounded-xl px-6 bg-base-content text-base-100 border-none hover:bg-base-content/80 !important;
  }

  /* 评论列表项美化 */
  .atk-comment-wrap {
    @apply border-b border-base-200/50 py-6 last:border-none !important;
  }

  .atk-nick {
    @apply font-bold text-base-content !important;
  }

  /* 隐藏 Artalk 自带的一些不协调的阴影 */
  .atk-layer.atk-main-editor {
    box-shadow: none !important;
  }

  /* 适配深色模式下的微调 */
  [data-theme="dark"] .comments-container {
    @apply bg-neutral/30 border-white/5;
  }
</style>
