---
/**
 * Comments.astro - Minimalist & Integrated Version
 * 评论组件 - 极简主义集成方案，彻底消除“嵌套感”
 */

const { title } = Astro.props;
const lang = Astro.currentLocale === "zh" ? "zh-CN" : "en";

const ARTALK_SERVER = "https://comment.peregrinewang.me";
const ARTALK_SITE = "Peregrine";
---

<div class="divider my-16 opacity-20"></div>

<div class="comments-section max-w-full">
  <div class="flex items-center gap-2 mb-10 px-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <h2 class="text-lg font-bold tracking-tight opacity-70 uppercase">{lang === 'zh-CN' ? '交流与反馈' : 'Comments'}</h2>
  </div>

  <div class="comments-wrapper relative min-h-[250px]">
    <!-- 精简骨架屏 -->
    <div id="ArtalkSkeleton" class="absolute inset-0 flex flex-col gap-6 w-full transition-opacity duration-700 z-10">
      <div class="skeleton h-32 w-full opacity-10 rounded-2xl"></div>
      <div class="skeleton h-20 w-full opacity-5 rounded-2xl"></div>
    </div>

    <!-- 评论区容器 -->
    <div id="ArtalkComments" class="opacity-0 transition-all duration-1000 relative z-20"></div>
  </div>
</div>

<link href={`${ARTALK_SERVER}/dist/Artalk.css`} rel="stylesheet" />
<script src={`${ARTALK_SERVER}/dist/Artalk.js`} is:inline></script>

<script is:inline define:vars={{ ARTALK_SERVER, ARTALK_SITE, lang, title }}>
  function initArtalk() {
    const el = document.getElementById("ArtalkComments");
    if (!el || el.classList.contains('artalk-initialized')) return;

    const artalk = Artalk.init({
      el: "#ArtalkComments",
      pageKey: window.location.pathname,
      pageTitle: title,
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      darkMode: "auto",
      locale: lang,
      pv: true,
    });

    artalk.on('list-loaded', () => {
      const skeleton = document.getElementById("ArtalkSkeleton");
      const comments = document.getElementById("ArtalkComments");
      
      if (skeleton) {
        skeleton.classList.add("opacity-0");
        setTimeout(() => skeleton.style.display = 'none', 700); 
      }
      if (comments) {
        comments.classList.remove("opacity-0");
        comments.classList.add("artalk-initialized");
      }
    });
  }

  document.addEventListener("astro:page-load", initArtalk);
</script>

<style is:global>
  /* 基础变量重写 */
  :root {
    --at-color-main: oklch(var(--p)) !important;
    --at-color-bg: transparent !important;
    --at-color-border: oklch(var(--bc) / 0.08) !important;
    --at-color-font: oklch(var(--bc)) !important;
    --at-color-deep: oklch(var(--b2)) !important;
    --at-color-sub: oklch(var(--bc) / 0.5) !important;
  }

  /* 彻底消除外部容器感，让 Artalk 直接融入页面背景 */
  .comments-wrapper {
    @apply px-0;
  }

  /* 编辑器区域美化 */
  .atk-main-editor {
    @apply border border-base-content/5 bg-base-content/[0.02] rounded-3xl p-4 transition-all duration-500 focus-within:bg-base-100 focus-within:shadow-xl focus-within:shadow-base-content/5 !important;
    box-shadow: none !important;
  }

  /* 昵称/邮箱/网址 输入框：改为极简下划线风格 */
  .atk-header {
    @apply flex flex-wrap gap-2 mb-4 !important;
  }

  .atk-header input {
    @apply bg-transparent border-b border-base-content/10 px-2 py-2 text-sm transition-all focus:border-primary !important;
    border-top: none !important;
    border-left: none !important;
    border-right: none !important;
    border-radius: 0 !important;
  }

  /* 发送按钮 */
  .atk-send-btn {
    @apply btn btn-primary btn-md rounded-2xl px-10 border-none transition-all shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 !important;
  }

  /* 评论列表 */
  .atk-list {
    @apply mt-12 !important;
  }

  .atk-comment-wrap {
    @apply border-none bg-base-content/[0.01] mb-4 p-6 rounded-3xl transition-colors hover:bg-base-content/[0.03] !important;
  }

  .atk-avatar img {
    @apply rounded-2xl !important;
  }

  /* 修正所有残留的蓝色 */
  .atk-content a, .atk-nick, .atk-item.active, .atk-layer-wrap a {
    color: oklch(var(--p)) !important;
  }

  .atk-footer, .atk-power {
    @apply opacity-30 text-[10px] grayscale transition-all hover:opacity-100 hover:grayscale-0 !important;
  }

  /* 下拉菜单和弹出层 */
  .atk-layer-wrap {
    @apply rounded-2xl shadow-2xl border border-base-content/10 backdrop-blur-xl bg-base-100/90 !important;
  }

  /* 适配暗色模式 */
  [data-theme="dark"] .atk-main-editor {
    @apply bg-white/[0.03] focus-within:bg-neutral !important;
  }
</style>
