---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../../styles/global.css";

export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description,
  image = "/social_img.webp",
  ogType = "website",
  noindex = false,
  pubDate,
  updatedDate,
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700;800&family=Google+Sans+Flex:wght@400;700&family=Noto+Sans+SC:wght@400;700&family=Noto+Serif+SC:wght@400;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
<meta name="generator" content={Astro.generator} />

{noindex && <meta name="robots" content="noindex, follow" />}

<!-- Canonical URL -->
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

<!-- Hreflang Tags -->
<link
  rel="alternate"
  hreflang="en"
  href={new URL(Astro.url.pathname.replace(/^\/zh/, "") || "/", Astro.site)}
/>
<link
  rel="alternate"
  hreflang="zh"
  href={new URL(
    "/zh" + (Astro.url.pathname.replace(/^\/zh/, "") || "/"),
    Astro.site,
  )}
/>
<link
  rel="alternate"
  hreflang="x-default"
  href={new URL(Astro.url.pathname.replace(/^\/zh/, "") || "/", Astro.site)}
/>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- JSON-LD -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Peregrine Wang",
    url: Astro.site,
    sameAs: ["https://github.com/peregrine-phi"],
    jobTitle: "Full Stack Lifeplayer",
    description: description,
  })}
/>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: title,
    url: Astro.site,
    description: description,
  })}
/>

{ogType === 'article' && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description: description,
      image: [new URL(image, Astro.url)],
      datePublished: pubDate?.toISOString(),
      dateModified: updatedDate?.toISOString() || pubDate?.toISOString(),
      author: [{
          "@type": "Person",
          "name": "Peregrine Wang",
          "url": Astro.site
        }]
    })}
  />
)}
