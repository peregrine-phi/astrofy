---
import SideBarFooter from "./SideBarFooter.astro";
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguagePicker from "../ui/LanguagePicker.astro";
import ThemeSelector from "../ui/ThemeSelector.astro";


import Search from "../ui/Search.astro";


const { sideBarActiveItemID } = Astro.props;
const lang = Astro.currentLocale || "en";
---

<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside class="px-2 pt-2 h-auto min-h-full w-[19rem] bg-base-200 text-base-content flex flex-col">
    <div class="w-fit mx-auto mt-5 mb-6">
      <a href={getRelativeLocaleUrl(lang, "")}>
        <div class="avatar transition ease-in-out hover:scale-[102%] block m-auto">
          <div class="w-[8.5rem]">
            <Image class="mask mask-circle" format="webp" width={300} height={300} src="/profile.webp" alt="Profile image" />
          </div>
        </div>
      </a>
    </div>
    <Search />
    <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    <div class="grow"></div>
    
    <div class="flex items-center justify-center gap-2 mb-2 px-4">
      <LanguagePicker />
      <div class="divider divider-horizontal m-0 w-1 opacity-20"></div>
      <ThemeSelector />
    </div>

    <SideBarFooter />
  </aside>
</div>
