---
import { type BlogSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import { getRelativeLocaleUrl } from "astro:i18n";

export interface Props extends BlogSchema {}

const { title, description, pubDate, updatedDate, heroImage, badge, tags = [], block_region } = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll")
import { Image } from "astro:assets";
import Comments from "../components/ui/Comments.astro";
import TableOfContents from "../components/ui/TableOfContents.astro";
---

<BaseLayout title={title} description={description} image={heroImage} ogType="article" pubDate={pubDate} updatedDate={updatedDate} block_region={block_region}>
  <div class="flex flex-col lg:flex-row lg:justify-center gap-12" data-block-region={block_region}>
    <article class="prose prose-lg max-w-[750px] w-full relative">
      <TableOfContents mode="mobile" />
      {heroImage && <Image width={750} height={422} format="webp" src={heroImage} alt={title} class="w-full mb-6" />}
      <h1 class="title my-2 text-4xl font-bold">{title}</h1>
      {pubDate && <time>{displayDate}</time>}
      <br />
      {badge && <div class="badge badge-secondary my-1">{badge}</div>}
      {
        tags &&
          tags.map((tag) => (
            <a href={getRelativeLocaleUrl(Astro.currentLocale || "en", `blog/tag/${tag}`)} class="badge badge-outline ml-2 no-underline">
              {tag}
            </a>
          ))
      }
      {
        updatedDate && (
          <div>
            {" "}
            Last updated on <time>{updatedDate}</time>{" "}
          </div>
        )
      }
      <div class="divider my-2"></div>
      <slot />
      <Comments title={title} />
    </article>
    <aside class="hidden lg:block w-[220px] shrink-0">
      <TableOfContents mode="desktop" />
    </aside>
  </div>
</BaseLayout>
