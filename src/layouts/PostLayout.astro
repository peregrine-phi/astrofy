---
import { type BlogSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import { getRelativeLocaleUrl } from "astro:i18n";

export interface Props extends BlogSchema {}

const { title, description, pubDate, updatedDate, heroImage, badge, tags = [], block_region } = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll")
import { Image } from "astro:assets";
import Comments from "../components/ui/Comments.astro";
---

<BaseLayout title={title} description={description} image={heroImage} ogType="article" pubDate={pubDate} updatedDate={updatedDate}>
  <script is:inline define:vars={{ block_region }}>
    function checkAccess() {
      if (block_region === 'CN') {
        const country = sessionStorage.getItem('user-country');
        if (country === 'CN') {
          // 如果是屏蔽地区，隐藏内容并重定向
          document.documentElement.style.display = 'none';
          window.location.href = '/';
        }
      }
    }
    checkAccess();
    document.addEventListener('astro:after-swap', checkAccess);
  </script>
  <main class="md:flex md:justify-center" data-block-region={block_region}>
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto">
      {heroImage && <Image width={750} height={422} format="webp" src={heroImage} alt={title} class="w-full mb-6" />}
      <h1 class="title my-2 text-4xl font-bold">{title}</h1>
      {pubDate && <time>{displayDate}</time>}
      <br />
      {badge && <div class="badge badge-secondary my-1">{badge}</div>}
      {
        tags &&
          tags.map((tag) => (
            <a href={getRelativeLocaleUrl(Astro.currentLocale || "en", `blog/tag/${tag}`)} class="badge badge-outline ml-2 no-underline">
              {tag}
            </a>
          ))
      }
      {
        updatedDate && (
          <div>
            {" "}
            Last updated on <time>{updatedDate}</time>{" "}
          </div>
        )
      }
      <div class="divider my-2"></div>
      <slot />
      <Comments title={title} />
    </article>
  </main>
</BaseLayout>
