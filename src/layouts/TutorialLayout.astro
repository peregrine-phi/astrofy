---
import { type TutorialSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

export interface Props extends TutorialSchema {}

const {
  title,
  description,
  updatedDate,
  heroImage,
  badge,
  custom_link,
  custom_link_label,
  block_region,
} = Astro.props;

dayjs.extend(localizedFormat);
const displayDate = dayjs(updatedDate).format("ll");
import { Image } from "astro:assets";
import Comments from "../components/ui/Comments.astro";
import TableOfContents from "../components/ui/TableOfContents.astro";
---

<BaseLayout title={title} description={description} image={heroImage} updatedDate={updatedDate} block_region={block_region}>
  <div class="flex flex-col lg:flex-row lg:justify-center gap-12" data-block-region={block_region}>
    <article class="prose prose-lg max-w-[750px] w-full relative" data-pagefind-body>
      <TableOfContents mode="mobile" />
      {
        heroImage && (
          <Image width={750} height={422} format="webp" src={heroImage} alt={title} class="w-full mb-6" />
        )
      }
      <div class="">
        <h1 class="title my-2 text-4xl font-bold">
          {title}
          {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
        </h1>
        <div class="flex place-content-between items-center">
          <div class="grow md:grow-0">
            {updatedDate && <span class="text-sm opacity-70">Updated: {displayDate}</span>}
          </div>
          <div>
            {
              custom_link && (
                <a class="btn btn-primary grow md:grow-0 ml-4" href={custom_link} target="_blank">
                  {custom_link_label || "View Tutorial"}
                </a>
              )
            }
          </div>
        </div>
      </div>
      <div class="divider my-2"></div>
      <slot />
      <Comments title={title} />
    </article>
    <aside class="hidden lg:block w-[220px] shrink-0">
      <TableOfContents mode="desktop" />
    </aside>
  </div>
</BaseLayout>

<script is:inline>
  function addAnchorLinks() {
    const article = document.querySelector('article[data-pagefind-body]');
    if (!article) return;
    const headings = article.querySelectorAll('h2, h3, h4');
    
    headings.forEach(heading => {
      if (heading.id && !heading.querySelector('.anchor-link')) {
        const anchor = document.createElement('a');
        anchor.className = 'anchor-link';
        anchor.href = `#${heading.id}`;
        anchor.ariaLabel = 'Direct link to this section';
        anchor.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>';
        
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const url = new URL(window.location.href);
          url.hash = heading.id;
          navigator.clipboard.writeText(url.toString());
          window.location.hash = heading.id;
        });

        heading.style.position = 'relative';
        heading.prepend(anchor);
      }
    });
  }

  addAnchorLinks();
  document.addEventListener('astro:page-load', addAnchorLinks);
</script>

<style is:global>
  .anchor-link {
    position: absolute;
    left: -1.75rem;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0;
    transition: all 0.2s ease;
    color: oklch(var(--p));
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
  }
  
  .anchor-link:hover {
    background-color: oklch(var(--p) / 0.1);
  }

  h2:hover .anchor-link,
  h3:hover .anchor-link,
  h4:hover .anchor-link {
    opacity: 0.6;
  }

  .anchor-link:hover {
    opacity: 1 !important;
  }

  @media (max-width: 1024px) {
    .anchor-link {
      display: none;
    }
  }
</style>
