---
import BaseHead from "../components/layout/BaseHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import SideBar from "../components/layout/SideBar.astro";
import { ViewTransitions } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title,
  description,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
  noindex,
  pubDate,
  updatedDate,
} = Astro.props;

const isZh = Astro.currentLocale === "zh";
const defaultTitle = isZh ? "悠道 | 数字花园" : SITE_TITLE;
const defaultDescription = isZh ? "Full Stack Lifeplayer - 悠道的数字花园" : SITE_DESCRIPTION;

const finalTitle = title || defaultTitle;
const finalDescription = description || defaultDescription;

// --- Loading Indicator Theme Logic ---
const today = new Date();
const month = today.getMonth() + 1;
const day = today.getDate();

let loaderColor = "oklch(var(--p))"; // Default daisyUI primary (v4 uses oklch!)
let loaderHeight = "2px";

if (month === 6 || month === 5) {
  // Pride Month & Testing (May/June) Rainbow
  loaderColor = "linear-gradient(90deg, #ff0000, #ff8700, #ffd300, #deff0a, #a1ff0a, #0aff99, #0aefff, #147df5, #580aff, #be0aff)";
} else if (month === 3 && day === 8) {
  // Women's Day Purple
  loaderColor = "linear-gradient(90deg, #8e44ad, #d2b4de)";
} else {
  // Programmer's Day (Day 256)
  const year = today.getFullYear();
  const isLeapYear = (year % 4 === 0 && year % 100 !== 0) || (year % 400 === 0);
  const dayOfYear = Math.floor((today.getTime() - new Date(year, 0, 0).getTime()) / 86400000);
  if (isLeapYear ? dayOfYear === 257 : dayOfYear === 256) {
    loaderColor = "#00ff41";
  }
}
---

<!doctype html>
<html lang={Astro.currentLocale || "en"}>
  <head>
    <BaseHead title={finalTitle} description={finalDescription} image={image} ogType={ogType} noindex={noindex} pubDate={pubDate} updatedDate={updatedDate} />
    {TRANSITION_API && <ViewTransitions />}
    
    {/* Theme initialization script - runs before any rendering to prevent FOUC */}
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
      } else {
        // Default theme if none saved
        document.documentElement.setAttribute('data-theme', 'lofi');
      }
    </script>

    
    {/* 将进度条组件移至 head 中，防止 View Transitions 导致重复初始化 */}
    <LoadingIndicator color="transparent" height={loaderHeight} threshold={0} />
    <style is:global define:vars={{ loaderBg: loaderColor }}>
      .astro-loading-indicator {
        background: var(--loaderBg) !important;
        box-shadow: 0 0 10px var(--loaderBg);
        z-index: 99999 !important;
      }
    </style>
  </head>
  <body>
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        <Header title={SITE_TITLE} transition:persist />
        <div class="md:flex md:justify-center">
          <main class="p-6 pt-10 lg:max-w-[900px] max-w-[100vw] w-full">
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} transition:persist />}
    </div>
  </body>
</html>
